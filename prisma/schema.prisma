generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    Int              @id @default(autoincrement())
  publicId              String           @unique
  name                  String           @unique
  email                 String           @unique
  password              String
  isPrivate             Boolean          @default(false)
  isEmailVerified       Boolean          @default(false)
  createdAt             DateTime         @default(now())
  imageId               Int?             @unique
  updatedAt             DateTime         @updatedAt
  isBlocked             Boolean          @default(false)
  deletedAt             DateTime?
  role                  String           @default("user")
  comments              Comment[]
  friendedBy            Friends[]        @relation("UserFriendsOf")
  friends               Friends[]        @relation("UserFriends")
  groupsRequests        GroupRequests[]
  notificationsSent     Notifications[]  @relation("NotificationActor")
  notificationsReceived Notifications[]  @relation("NotificationRecipient")
  posts                 Post[]
  profile               Profile[]
  reacts                React[]
  image                 image?           @relation(fields: [imageId], references: [id])
  loginSession          loginSession[]
  membersOfGroup        membersOfGroup[]
  savedPosts            savedPosts[]
}

model Profile {
  id          Int      @id @default(autoincrement())
  bio         String?
  gender      String?
  dateOfBirth DateTime
  city        String?
  country     String?
  school      String?
  education   String?
  work        String?
  userId      Int      @unique
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model Post {
  id            Int          @id @default(autoincrement())
  content       String
  groupId       Int?
  loveCount     Int          @default(0)
  hahaCount     Int          @default(0)
  eggCount      Int          @default(0)
  wowCount      Int          @default(0)
  sadCount      Int          @default(0)
  angryCount    Int          @default(0)
  commentCount  Int          @default(0)
  shareCount    Int          @default(0)
  userId        Int
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  isPrivate     Boolean      @default(false)
  DeletedAt     DateTime?
  type          String       @default("Normal")
  parentPostId  Int?
  commentOnPost String?
  comments      Comment[]
  group         Group?       @relation(fields: [groupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentPost    Post?        @relation("RePostRelation", fields: [parentPostId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rePosts       Post[]       @relation("RePostRelation")
  author        User         @relation(fields: [userId], references: [id])
  images        PostImage[]
  reacts        React[]
  savedPosts    savedPosts[]
}

model Group {
  id             Int              @id @default(autoincrement())
  name           String
  description    String?
  rules          String?
  coverId        Int?             @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  cover          image?           @relation(fields: [coverId], references: [id])
  requests       GroupRequests[]
  posts          Post[]
  membersOfGroup membersOfGroup[]
}

model React {
  id        Int    @id @default(autoincrement())
  postId    Int
  userId    Int
  reactType String
  post      Post   @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User   @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@unique([postId, userId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  content   String
  imageId   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  image     image?   @relation(fields: [imageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onUpdate: NoAction)
}

model Friends {
  id        Int      @id @default(autoincrement())
  userId    Int
  friendId  Int
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  friend    User     @relation("UserFriendsOf", fields: [friendId], references: [id], onUpdate: NoAction)
  user      User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model GroupRequests {
  id         Int      @id @default(autoincrement())
  groupId    Int
  userId     Int
  targetType String
  targetId   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  group      Group    @relation(fields: [groupId], references: [id], onUpdate: NoAction)
  user       User     @relation(fields: [userId], references: [id], onUpdate: NoAction)
}

model Notifications {
  id          Int      @id @default(autoincrement())
  recipientId Int
  actorId     Int
  actionType  String
  entityType  String
  entityId    Int
  content     String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  actor       User     @relation("NotificationActor", fields: [actorId], references: [id], onUpdate: NoAction)
  recipient   User     @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model PostImage {
  id      Int   @id @default(autoincrement())
  postId  Int
  imageId Int
  image   image @relation(fields: [imageId], references: [id], onUpdate: NoAction)
  post    Post  @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model image {
  id             Int         @id @default(autoincrement())
  publicId       String      @unique
  fileName       String
  filePath       String
  orderIndex     Int         @default(1)
  description    String?
  createdAt      DateTime    @default(now())
  imageInComment Comment[]
  coverGroup     Group?
  post           PostImage[]
  user           User?
}

model loginSession {
  id           Int      @id @default(autoincrement())
  userId       Int
  refreshToken String   @unique
  createdAt    DateTime @default(now())
  expireAt     DateTime
  User         User     @relation(fields: [userId], references: [id], onUpdate: NoAction)
}

model membersOfGroup {
  id       Int      @id @default(autoincrement())
  groupId  Int
  userId   Int
  role     String   @default("member")
  joinedAt DateTime @default(now())
  Group    Group    @relation(fields: [groupId], references: [id], onUpdate: NoAction)
  User     User     @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model savedPosts {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  createdAt DateTime @default(now())
  Post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User      User     @relation(fields: [userId], references: [id], onUpdate: NoAction)
}
